<Window x:Class="FoTestingApp.Views.MainShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Jinom Test"
        MinWidth="1024" MinHeight="640"
        Width="1280" Height="768"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}">

    <Window.Resources>
        <!-- Top Nav Button (inactive) -->
        <Style x:Key="NavButtonStyle" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Top Nav Button (active) -->
        <Style x:Key="NavButtonActiveStyle" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Top Navigation Bar ═══ -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="10" Padding="6">
                        <materialDesign:PackIcon Kind="LanConnect" Foreground="{DynamicResource PrimaryBrush}" Width="24" Height="24"/>
                    </Border>
                    <TextBlock Text="Jinom" FontSize="20" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextDarkBrush}"/>
                    <TextBlock Text="Test" FontSize="20" FontWeight="Light" VerticalAlignment="Center" Foreground="{DynamicResource TextLightBrush}" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Center Nav Items -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button x:Name="BtnDashboard" Style="{StaticResource NavButtonActiveStyle}"
                            Click="NavButton_Click" Tag="Dashboard">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnNewTest" Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="NewTest">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PlayCircle" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Pengujian Baru" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnHistory" Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="History">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="History" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Riwayat" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnReport" Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="Report">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileDocument" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Laporan" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnSettings" Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="Settings" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cog" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Pengaturan" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Right: User Info + Logout -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Status badge -->
                    <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="14" Padding="10,4" Margin="0,0,12,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="{DynamicResource PassGreenBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Online" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- User avatar + name -->
                    <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="20" Padding="4,4,12,4" VerticalAlignment="Center" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource PrimaryBrush}">
                                <materialDesign:PackIcon Kind="Account" Foreground="White" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="UserNameLabel" Text="Teknisi" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}"/>
                                <TextBlock x:Name="UserEmailLabel" Text="-" FontSize="10" Foreground="{DynamicResource TextLightBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Logout button -->
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Click="LogoutButton_Click" ToolTip="Keluar"
                            Width="36" Height="36" Margin="8,0,0,0"
                            Foreground="{DynamicResource TextLightBrush}">
                        <materialDesign:PackIcon Kind="Logout" Width="18" Height="18"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Main Content Area ═══ -->
        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               NavigationUIVisibility="Hidden"
               Background="{DynamicResource AppBackgroundBrush}"/>
    </Grid>
</Window>
