<Window x:Class="FoTestingApp.Views.MainShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="FO Testing &amp; Commissioning — Jinom AI"
        MinWidth="1024" MinHeight="640"
        Width="1280" Height="768"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6FA">

    <Window.Resources>
        <!-- Inactive Navigation Button Style -->
        <Style x:Key="NavButtonStyle" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="{StaticResource ButtonCornerRadius}"/>
        </Style>

        <!-- Active Navigation Button Style -->
        <Style x:Key="NavButtonActiveStyle" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="{StaticResource ButtonCornerRadius}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1" Background="{DynamicResource CardBackgroundBrush}">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="LanConnect" Foreground="{DynamicResource PrimaryBrush}" Width="32" Height="32" />
                    <TextBlock Text="NetPulse" FontSize="20" FontWeight="Bold" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextDarkBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource PrimaryLightBrush}" BorderBrush="#33ec5b13" BorderThickness="1" CornerRadius="16" Padding="12,4" Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="NETWORK ONLINE" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- User Info Top Right -->
                    <StackPanel Margin="0,0,16,0" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock x:Name="UserNameLabel" Text="Teknisi" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}" HorizontalAlignment="Right" FontSize="14"/>
                        <TextBlock x:Name="UserEmailLabel" Text="-" FontSize="11" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Right"/>
                    </StackPanel>
                    <Ellipse Width="40" Height="40" Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="2" Fill="{DynamicResource BorderLightBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sidebar -->
        <Border Grid.Row="1" Grid.Column="0" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,1,0" Background="{DynamicResource CardBackgroundBrush}">
            <DockPanel Margin="16">
                <!-- User Info Badge in Sidebar -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="12,16,12,24">
                    <Border Background="#33ec5b13" CornerRadius="8" Padding="8">
                        <materialDesign:PackIcon Kind="Person" Foreground="{DynamicResource PrimaryBrush}" Width="24" Height="24" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Admin Portal" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}" />
                        <TextBlock Text="Network Engineer" FontSize="12" Foreground="{DynamicResource TextLightBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Logout at bottom -->
                <Button DockPanel.Dock="Bottom" Style="{StaticResource NavButtonStyle}"
                        Click="LogoutButton_Click" Margin="0,12,0,24" VerticalAlignment="Bottom"
                        Foreground="{DynamicResource FailRedBrush}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Logout" Width="20" Height="20" VerticalAlignment="Center"/>
                        <TextBlock Text="Keluar" VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="Bold"/>
                    </StackPanel>
                </Button>

                <!-- Navigation Items -->
                <StackPanel DockPanel.Dock="Top">
                    <Button x:Name="BtnDashboard" Style="{StaticResource NavButtonActiveStyle}"
                            Click="NavButton_Click" Tag="Dashboard">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnNewTest" Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="NewTest">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Play" Width="20" Height="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Pengujian Baru" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnHistory" Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="History">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="History" Width="20" Height="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Riwayat" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnReport" Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="Report">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FilePdfBox" Width="20" Height="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Laporan" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Separator Margin="12,12" Background="{DynamicResource BorderLightBrush}"/>

                    <Button x:Name="BtnSettings" Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="Settings" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Settings" Width="20" Height="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Pengaturan" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Frame x:Name="ContentFrame"
               Grid.Row="1" Grid.Column="1"
               NavigationUIVisibility="Hidden"
               Background="{DynamicResource AppBackgroundBrush}"/>
    </Grid>
</Window>
