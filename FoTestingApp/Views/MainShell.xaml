<Window x:Class="FoTestingApp.Views.MainShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Jinom Test"
        MinWidth="1024" MinHeight="640"
        Width="1280" Height="768"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}">

    <Window.Resources>
        <!-- Sidebar Nav Button (inactive) -->
        <Style x:Key="NavButtonStyle" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="12,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Sidebar Nav Button (active) -->
        <Style x:Key="NavButtonActiveStyle" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryDarkBrush}"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="12,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Sidebar Navigation ═══ -->
        <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,1,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" Direction="0" ShadowDepth="2"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="24,24,24,32">
                    <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="10" Padding="8">
                        <materialDesign:PackIcon Kind="LanConnect" Foreground="{DynamicResource PrimaryBrush}" Width="28" Height="28"/>
                    </Border>
                    <TextBlock Text="Jinom" FontSize="24" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextDarkBrush}"/>
                    <TextBlock Text="Test" FontSize="24" FontWeight="Light" VerticalAlignment="Center" Foreground="{DynamicResource TextLightBrush}" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel Grid.Row="1">
                    <Button x:Name="BtnDashboard" Style="{StaticResource NavButtonActiveStyle}"
                            Click="NavButton_Click" Tag="Dashboard">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnNewTest" Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="NewTest">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TestTube" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Pengujian Baru" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnSettings" Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="Settings" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cog" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Pengaturan" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- User Info & Logout -->
                <StackPanel Grid.Row="3" Margin="16,0,16,24">
                    <!-- Status badge -->
                    <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="8" Padding="12,6" Margin="0,0,0,16" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource PassGreenBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Sistem Online &amp; Terhubung" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryDarkBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="12" Padding="12" BorderThickness="1" BorderBrush="{DynamicResource BorderLightBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{DynamicResource PrimaryBrush}">
                                <materialDesign:PackIcon Kind="Account" Foreground="White" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="UserNameLabel" Text="Teknisi" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="UserEmailLabel" Text="email@jinom.net" FontSize="11" Foreground="{DynamicResource TextLightBrush}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            
                            <!-- Logout icon -->
                            <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}"
                                    Click="LogoutButton_Click" ToolTip="Keluar"
                                    Width="32" Height="32" Margin="4,0,0,0"
                                    Foreground="{DynamicResource TextLightBrush}">
                                <materialDesign:PackIcon Kind="LogoutVariant" Width="18" Height="18"/>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Main Content Area ═══ -->
        <Grid Grid.Column="1" Background="{DynamicResource AppBackgroundBrush}">
            <materialDesign:TransitioningContent>
                <materialDesign:TransitioningContent.OpeningEffect>
                    <materialDesign:TransitionEffect Kind="FadeIn" Duration="0:0:0.3"/>
                </materialDesign:TransitioningContent.OpeningEffect>
                <Frame x:Name="ContentFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"/>
            </materialDesign:TransitioningContent>

            <!-- Floating Action Button for "New Test" to make it highly visible on every page except New Test -->
            <Button x:Name="FabNewTest"
                    Style="{StaticResource MaterialDesignFloatingActionButton}"
                    Background="{DynamicResource PrimaryBrush}"
                    BorderBrush="{DynamicResource PrimaryBrush}"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,32,32" Width="64" Height="64"
                    Click="FabNewTest_Click" ToolTip="Mulai Pengujian Baru">
                <materialDesign:PackIcon Kind="PlusNetwork" Width="32" Height="32" Foreground="White" />
            </Button>
        </Grid>

    </Grid>
</Window>
