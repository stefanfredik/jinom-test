<Window x:Class="FoTestingApp.Views.MainShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Jinom Test"
        MinWidth="1024" MinHeight="640"
        Width="1280" Height="768"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}">

    <Window.Resources>
        <!-- Navbar Nav Button (inactive) -->
        <Style x:Key="NavButtonStyle" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Navbar Nav Button (active) -->
        <Style x:Key="NavButtonActiveStyle" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryDarkBrush}"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Top Navigation / Header ═══ -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" Direction="270" ShadowDepth="2"/>
            </Border.Effect>
            
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Logo -->
                    <ColumnDefinition Width="*"/>    <!-- Center Menus -->
                    <ColumnDefinition Width="Auto"/> <!-- Right Tools -->
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="10" Padding="8">
                        <materialDesign:PackIcon Kind="LanConnect" Foreground="{DynamicResource PrimaryBrush}" Width="24" Height="24"/>
                    </Border>
                    <TextBlock Text="Jinom" FontSize="20" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextDarkBrush}"/>
                    <TextBlock Text="Test" FontSize="20" FontWeight="Light" VerticalAlignment="Center" Foreground="{DynamicResource TextLightBrush}" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Center Navigation Menu -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button x:Name="BtnDashboard" Style="{StaticResource NavButtonActiveStyle}"
                            Click="NavButton_Click" Tag="Dashboard">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnNewTest" Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="NewTest">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TestTube" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Pengujian Baru" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnSettings" Style="{StaticResource NavButtonStyle}"
                            Click="NavButton_Click" Tag="Settings" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cog" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Pengaturan" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Right Side Tools & Profile -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    
                    <!-- Theme Toggle -->
                    <Button x:Name="BtnToggleTheme" Style="{StaticResource MaterialDesignIconButton}"
                            Click="BtnToggleTheme_Click" ToolTip="Ubah Tampilan Terang/Gelap"
                            Foreground="{DynamicResource TextLightBrush}" Width="36" Height="36" Margin="0,0,16,0">
                        <materialDesign:PackIcon x:Name="IconTheme" Kind="Brightness2" Width="20" Height="20"/>
                    </Button>

                    <Rectangle Width="1" Height="32" Fill="{DynamicResource BorderLightBrush}" Margin="0,0,16,0"/>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,12,0" VerticalAlignment="Center">
                            <TextBlock x:Name="UserNameLabel" Text="Teknisi" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="UserEmailLabel" Text="email@jinom.net" FontSize="11" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Right"/>
                        </StackPanel>
                        
                        <!-- Dropdown Menu / User icon -->
                        <materialDesign:PopupBox PlacementMode="BottomAndAlignRightEdges" StaysOpen="False" ToolTip="Profil">
                            <materialDesign:PopupBox.ToggleContent>
                                <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource PrimaryBrush}" Cursor="Hand">
                                    <materialDesign:PackIcon Kind="Account" Foreground="White" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </materialDesign:PopupBox.ToggleContent>
                            <StackPanel Width="150" Margin="0,8">
                                <Button Content="Sign Out" Click="LogoutButton_Click" Foreground="{DynamicResource FailRedBrush}"/>
                            </StackPanel>
                        </materialDesign:PopupBox>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Main Content Area ═══ -->
        <Grid Grid.Row="1" Background="{DynamicResource AppBackgroundBrush}">
            <materialDesign:TransitioningContent>
                <materialDesign:TransitioningContent.OpeningEffect>
                    <materialDesign:TransitionEffect Kind="FadeIn" Duration="0:0:0.3"/>
                </materialDesign:TransitioningContent.OpeningEffect>
                <Frame x:Name="ContentFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"/>
            </materialDesign:TransitioningContent>

            <!-- Floating Action Button for "New Test" -->
            <Button x:Name="FabNewTest"
                    Style="{StaticResource MaterialDesignFloatingActionButton}"
                    Background="{DynamicResource PrimaryBrush}"
                    BorderBrush="{DynamicResource PrimaryBrush}"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,32,32" Width="64" Height="64"
                    Click="FabNewTest_Click" ToolTip="Mulai Pengujian Baru">
                <materialDesign:PackIcon Kind="PlusNetwork" Width="32" Height="32" Foreground="White" />
            </Button>
        </Grid>

    </Grid>
</Window>
