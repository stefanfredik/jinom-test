<Window x:Class="FoTestingApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="FO Testing &amp; Commissioning — Login"
        Height="560" Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="180"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Banner -->
        <Border Grid.Row="0" Background="#1E5AA0" CornerRadius="0,0,0,0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🔌" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Jinom AI" FontSize="22" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="FO Testing &amp; Commissioning" FontSize="13"
                           Foreground="#B3CCE8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Login Form -->
        <Border Grid.Row="1" Background="White" Margin="32,0,32,32"
                CornerRadius="8" Padding="28,24"
                Effect="{DynamicResource MaterialDesignShadowDepth2}">
            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="Masuk ke Akun Anda" FontSize="15" FontWeight="SemiBold"
                           Foreground="#1E5AA0" Margin="0,0,0,20"/>

                <!-- Email -->
                <materialDesign:PackIcon Kind="EmailOutline" Width="20" Height="20"
                                         Foreground="#666" Margin="0,0,0,4"/>
                <TextBox x:Name="EmailTextBox"
                         materialDesign:HintAssist.Hint="Email"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"
                         FontSize="14"/>

                <!-- Password -->
                <materialDesign:PackIcon Kind="LockOutline" Width="20" Height="20"
                                         Foreground="#666" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox"
                             materialDesign:HintAssist.Hint="Password"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             Margin="0,0,0,8"
                             FontSize="14"
                             KeyDown="PasswordBox_KeyDown"/>

                <!-- Error Message -->
                <TextBlock x:Name="ErrorMessage" Foreground="#E74C3C" FontSize="12"
                           Visibility="Collapsed" Margin="0,0,0,12" TextWrapping="Wrap"/>

                <!-- Login Button -->
                <Button x:Name="LoginButton"
                        Content="MASUK"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#1E5AA0"
                        Foreground="White"
                        FontSize="14" FontWeight="Bold"
                        Height="44"
                        Click="LoginButton_Click"
                        Margin="0,8,0,0"/>

                <!-- Loading Indicator -->
                <ProgressBar x:Name="LoadingBar"
                             Style="{StaticResource MaterialDesignLinearProgressBar}"
                             IsIndeterminate="True"
                             Visibility="Collapsed"
                             Margin="0,12,0,0"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
