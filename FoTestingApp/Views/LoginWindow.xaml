<Window x:Class="FoTestingApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="FO Testing &amp; Commissioning — Login"
        Height="560" Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Side: Branding -->
        <Border Grid.Column="0" Background="{DynamicResource JinomBlueBrush}" CornerRadius="0,0,0,0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16">
                <!-- Plug Icon -->
                <TextBlock Text="🔌" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="Jinom AI" FontSize="26" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                <!-- Line Separator -->
                <Border Height="2" Width="40" Background="#60A5FA" Margin="0,16,0,16"/>
                <TextBlock Text="FO Testing &amp; Commissioning" FontSize="14"
                           Foreground="{DynamicResource JinomLightBlueBrush}" HorizontalAlignment="Center"
                           TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,8"/>
            </StackPanel>
        </Border>

        <!-- Right Side: Login Form -->
        <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" Margin="0"
                Padding="32,48" CornerRadius="0">
            <StackPanel VerticalAlignment="Center" MaxWidth="320" HorizontalAlignment="Left">

                <TextBlock Text="Selamat Datang 👋" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource JinomDarkBlueBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="Silakan login untuk memulai pengujian." FontSize="14"
                           Foreground="#64748B" Margin="0,0,0,28"/>

                <!-- Email -->
                <TextBox x:Name="EmailTextBox"
                         materialDesign:HintAssist.Hint="Email / ID Teknisi"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,20"
                         Height="48"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         materialDesign:TextFieldAssist.LeadingIcon="EmailOutline"
                         materialDesign:TextFieldAssist.LeadingIconSize="20"/>

                <!-- Password -->
                <PasswordBox x:Name="PasswordBox"
                             materialDesign:HintAssist.Hint="Password"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             Margin="0,0,0,16"
                             Height="48"
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             materialDesign:TextFieldAssist.LeadingIcon="LockOutline"
                             materialDesign:TextFieldAssist.LeadingIconSize="20"
                             KeyDown="PasswordBox_KeyDown"/>

                <!-- Error Message -->
                <TextBlock x:Name="ErrorMessage" Foreground="{DynamicResource FailRedBrush}" FontSize="12"
                           Visibility="Collapsed" Margin="0,0,0,16" TextWrapping="Wrap"/>

                <!-- Login Button -->
                <Button x:Name="LoginButton"
                        Content="MASUK"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="{StaticResource ButtonCornerRadius}"
                        Background="{DynamicResource JinomBlueBrush}"
                        BorderBrush="{DynamicResource JinomBlueBrush}"
                        Foreground="White"
                        FontSize="15" FontWeight="Bold"
                        Height="48"
                        Click="LoginButton_Click"
                        Margin="0,8,0,0"/>

                <!-- Loading Indicator -->
                <ProgressBar x:Name="LoadingBar"
                             Style="{StaticResource MaterialDesignLinearProgressBar}"
                             IsIndeterminate="True"
                             Visibility="Collapsed"
                             Margin="0,16,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
