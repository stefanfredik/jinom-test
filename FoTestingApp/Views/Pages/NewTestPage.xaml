<Page x:Class="FoTestingApp.Views.Pages.NewTestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Pengujian Baru">

    <Grid Background="{DynamicResource AppBackgroundBrush}">

        <!-- ═══ Stage 1: Landing — Big circular start button ═══ -->
        <Grid x:Name="LandingContainer" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Title -->
                <TextBlock Text="Network Diagnostic" FontSize="36" FontWeight="Black" Foreground="{DynamicResource TextDarkBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Mulai pengujian jaringan fiber optik" FontSize="16" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Center" Margin="0,0,0,48"/>

                <!-- Big Circular Start Button -->
                <Grid HorizontalAlignment="Center" Margin="0,0,0,48">
                    <!-- Outer glow ring -->
                    <Ellipse Width="220" Height="220" StrokeThickness="3">
                        <Ellipse.Stroke>
                            <SolidColorBrush Color="#3022c55e"/>
                        </Ellipse.Stroke>
                    </Ellipse>
                    <!-- Middle ring -->
                    <Ellipse Width="200" Height="200" StrokeThickness="2">
                        <Ellipse.Stroke>
                            <SolidColorBrush Color="#2022c55e"/>
                        </Ellipse.Stroke>
                    </Ellipse>
                    <!-- Main button -->
                    <Button x:Name="StartLandingBtn" Width="180" Height="180" Click="StartLandingBtn_Click"
                            Style="{StaticResource MaterialDesignFloatingActionButton}"
                            Background="{DynamicResource PrimaryBrush}" BorderBrush="{DynamicResource PrimaryBrush}"
                            Foreground="White" Cursor="Hand">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="Play" Width="56" Height="56" HorizontalAlignment="Center"/>
                            <TextBlock Text="MULAI" FontSize="16" FontWeight="Black" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <TextBlock Text="Klik tombol di atas untuk memulai pengujian" FontSize="13" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ═══ Stage 2: Location Selection — POP or CPE ═══ -->
        <Grid x:Name="LocationContainer" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="700">
                <!-- Title -->
                <TextBlock Text="Pilih Lokasi Pengujian" FontSize="32" FontWeight="Black" Foreground="{DynamicResource TextDarkBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Tentukan lokasi pengujian yang akan dilakukan" FontSize="16" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Center" Margin="0,0,0,48"/>

                <!-- POP and CPE Cards -->
                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- POP Card -->
                    <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16"
                            BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1" Cursor="Hand"
                            MouseLeftButtonUp="PopCard_Click">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Color="Black" Opacity="0.06"/>
                        </Border.Effect>
                        <StackPanel HorizontalAlignment="Center" Margin="32">
                            <!-- Icon Circle -->
                            <Border Width="80" Height="80" CornerRadius="40" Background="{DynamicResource PrimaryLightBrush}" Margin="0,0,0,20" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="ServerNetwork" Width="36" Height="36" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="POP" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Point of Presence" FontSize="13" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="Pengujian di sisi infrastruktur backbone jaringan" FontSize="12" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>
                            <Button Content="Pilih POP" Click="PopCard_Click"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Background="{DynamicResource PrimaryBrush}" BorderBrush="{DynamicResource PrimaryBrush}"
                                    Foreground="White" FontWeight="Bold" Height="40" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                    <!-- CPE Card -->
                    <Border Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16"
                            BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1" Cursor="Hand"
                            MouseLeftButtonUp="CpeCard_Click">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Color="Black" Opacity="0.06"/>
                        </Border.Effect>
                        <StackPanel HorizontalAlignment="Center" Margin="32">
                            <!-- Icon Circle -->
                            <Border Width="80" Height="80" CornerRadius="40" Background="{DynamicResource PrimaryLightBrush}" Margin="0,0,0,20" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="RouterWireless" Width="36" Height="36" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="CPE" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Customer Premises Equipment" FontSize="13" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="Pengujian di sisi pelanggan dan perangkat akhir" FontSize="12" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>
                            <Button Content="Pilih CPE" Click="CpeCard_Click"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Background="{DynamicResource PrimaryBrush}" BorderBrush="{DynamicResource PrimaryBrush}"
                                    Foreground="White" FontWeight="Bold" Height="40" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Back button -->
                <Button Content="Kembali" Click="BackToLanding_Click" Margin="0,32,0,0"
                        Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource TextLightBrush}"
                        HorizontalAlignment="Center" Height="40"/>
            </StackPanel>
        </Grid>

        <!-- ═══ Stage 3: Form Area — Customer data input ═══ -->
        <ScrollViewer x:Name="FormContainer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
            <StackPanel Margin="32">
                <!-- Header -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock x:Name="FormTitle" Text="Customer Network Test" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}"/>
                    <TextBlock x:Name="FormSubtitle" Text="DIAGNOSTIC SUITE FOR CPE VERIFICATION" FontSize="11" FontWeight="Medium" Foreground="{DynamicResource TextLightBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Customer Configuration Panel -->
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Padding="32" Margin="0,0,0,32"
                        BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1">
                    <StackPanel>
                        <!-- Section Title -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="8" Padding="8">
                                <materialDesign:PackIcon x:Name="FormSectionIcon" Kind="AccountPlus" Foreground="{DynamicResource PrimaryBrush}" Width="24" Height="24"/>
                            </Border>
                            <TextBlock x:Name="FormSectionTitle" Text="Data Pengujian" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>

                        <!-- Data Fields -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel x:Name="PopSelectionPanel" Margin="0,0,0,16" Visibility="Collapsed">
                                    <TextBlock Text="PILIH POP" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextLightBrush}" Margin="0,0,0,8"/>
                                    <ComboBox x:Name="PopComboBox"
                                              Height="48"
                                              FontSize="14"
                                              DisplayMemberPath="DisplayName"
                                              SelectionChanged="PopComboBox_SelectionChanged"
                                              HorizontalContentAlignment="Stretch"/>
                                    <TextBlock x:Name="PopStatusText" FontSize="11" Foreground="{DynamicResource TextLightBrush}" Margin="0,6,0,0"/>
                                </StackPanel>

                                <StackPanel x:Name="CustomerSelectionPanel" Margin="0,0,0,16" Visibility="Collapsed">
                                    <TextBlock Text="PILIH PELANGGAN" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextLightBrush}" Margin="0,0,0,8"/>
                                    <ComboBox x:Name="CustomerComboBox"
                                              IsEditable="True"
                                              TextBoxBase.TextChanged="CustomerComboBox_TextChanged"
                                              Height="48"
                                              FontSize="14"
                                              DisplayMemberPath="DisplayName"
                                              SelectionChanged="CustomerComboBox_SelectionChanged"
                                              HorizontalContentAlignment="Stretch"/>
                                    <TextBlock x:Name="CustomerStatusText" FontSize="11" Foreground="{DynamicResource TextLightBrush}" Margin="0,6,0,0"/>
                                </StackPanel>

                                <TextBlock x:Name="NameFieldLabel" Text="NAMA PELANGGAN" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextLightBrush}" Margin="0,0,0,8"/>
                                <TextBox x:Name="FullNameBox"
                                         materialDesign:HintAssist.Hint="Masukkan nama"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Height="48" FontSize="14"
                                         VerticalContentAlignment="Center"
                                         materialDesign:TextFieldAssist.LeadingIcon="Account"
                                         BorderBrush="{DynamicResource BorderLightBrush}"
                                         Background="Transparent"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock x:Name="PackageFieldLabel" Text="PAKET INTERNET" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextLightBrush}" Margin="0,0,0,8"/>
                                <TextBox x:Name="PackageMbpsBox"
                                         materialDesign:HintAssist.Hint="Contoh: 100 Mbps"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Height="48" FontSize="14"
                                         VerticalContentAlignment="Center"
                                         materialDesign:TextFieldAssist.LeadingIcon="Speedometer"
                                         BorderBrush="{DynamicResource BorderLightBrush}"
                                         Background="Transparent"/>
                            </StackPanel>
                        </Grid>

                        <!-- Catatan -->
                        <StackPanel Margin="0,24,0,0">
                            <TextBlock Text="CATATAN" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextLightBrush}" Margin="0,0,0,8"/>
                            <TextBox x:Name="NotesBox"
                                     materialDesign:HintAssist.Hint="Catatan tambahan (opsional)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Height="80" FontSize="14"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top"
                                     materialDesign:TextFieldAssist.LeadingIcon="NoteTextOutline"
                                     BorderBrush="{DynamicResource BorderLightBrush}"
                                     Background="Transparent"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Action Toolbar -->
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Padding="16" Margin="0,0,0,32"
                        BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button x:Name="BackToLocationBtn" Margin="0,0,12,0"
                                    Height="52" Padding="16,0"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="12"
                                    BorderBrush="{DynamicResource BorderLightBrush}" Foreground="{DynamicResource TextLightBrush}"
                                    Click="BackToLocation_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ArrowLeft" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Kembali" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="StartTestBtn"
                                    Height="52" Padding="24,0"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="12"
                                    Background="{DynamicResource PrimaryBrush}" BorderBrush="{DynamicResource PrimaryBrush}" Foreground="White"
                                    Click="StartTestBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Play" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Mulai Pengujian" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ Stage 4: Progress Overlay ═══ -->
        <Grid x:Name="ProgressContainer" Visibility="Collapsed" Background="{DynamicResource AppBackgroundBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel HorizontalAlignment="Center" MaxWidth="640" Margin="24,48,24,48" Width="640">
                    
                    <!-- Title Section -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,48">
                        <TextBlock Text="Testing in Progress" FontSize="36" FontWeight="Black" Foreground="{DynamicResource TextDarkBrush}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Analyzing your network performance and security" FontSize="18" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Stepper Progress UI -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,48">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Step 1: Network -->
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <Border x:Name="Step1Circle" Width="48" Height="48" CornerRadius="24" Background="{DynamicResource PrimaryBrush}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="2" Margin="0,0,0,8">
                                    <materialDesign:PackIcon x:Name="Step1Icon" Kind="LanConnect" Foreground="White" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="Step1Text" Text="NETWORK" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <ProgressBar x:Name="Line1" Grid.Column="1" Value="0" Maximum="100" Height="4" VerticalAlignment="Top" Margin="0,22,0,0" Foreground="{DynamicResource PrimaryBrush}" Background="{DynamicResource BorderLightBrush}" BorderThickness="0"/>
                            
                            <!-- Step 2: Application -->
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <Border x:Name="Step2Circle" Width="48" Height="48" CornerRadius="24" Background="{DynamicResource AppBackgroundBrush}" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="2" Margin="0,0,0,8">
                                    <materialDesign:PackIcon x:Name="Step2Icon" Kind="Web" Foreground="{DynamicResource TextLightBrush}" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="Step2Text" Text="APPLICATION" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <ProgressBar x:Name="Line2" Grid.Column="3" Value="0" Maximum="100" Height="4" VerticalAlignment="Top" Margin="0,22,0,0" Foreground="{DynamicResource PrimaryBrush}" Background="{DynamicResource BorderLightBrush}" BorderThickness="0"/>
                            
                            <!-- Step 3: Speedtest -->
                            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                <Border x:Name="Step3Circle" Width="48" Height="48" CornerRadius="24" Background="{DynamicResource AppBackgroundBrush}" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="2" Margin="0,0,0,8">
                                    <materialDesign:PackIcon x:Name="Step3Icon" Kind="Speedometer" Foreground="{DynamicResource TextLightBrush}" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="Step3Text" Text="BANDWIDTH" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Current Task Card -->
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" BorderBrush="#1A22c55e" BorderThickness="1" Margin="0,0,0,40">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Color="{DynamicResource PrimaryColor}" Opacity="0.05"/>
                        </Border.Effect>
                        <StackPanel Margin="24">
                            <!-- Header -->
                            <Grid Margin="0,0,0,24">
                                <StackPanel HorizontalAlignment="Left">
                                    <TextBlock Text="CURRENT ACTIVITY" FontSize="10" FontWeight="Black" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="CurrentActivityText" Text="Preparing Tests..." FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}"/>
                                        <!-- Ping dot simulation -->
                                        <Ellipse Width="6" Height="6" Fill="{DynamicResource PrimaryBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="12" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="12,4">
                                    <TextBlock x:Name="TaskCountText" Text="Task 1 of 7" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextLightBrush}"/>
                                </Border>
                            </Grid>
                            
                            <!-- Internal Progress bar -->
                            <ProgressBar x:Name="SubTaskProgressBar" Value="0" Maximum="100" Height="16" materialDesign:ButtonAssist.CornerRadius="8" Foreground="{DynamicResource PrimaryBrush}" Background="{DynamicResource AppBackgroundBrush}" Margin="0,0,0,12"/>
                            
                            <Grid>
                                <TextBlock x:Name="SubTaskDetailText" Text="Initializing diagnostic engine..." FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextLightBrush}" FontStyle="Italic" HorizontalAlignment="Left"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Diagnostic Log List -->
                    <StackPanel>
                        <Grid Margin="4,0,4,8">
                            <TextBlock Text="DIAGNOSTIC LOG" FontSize="12" FontWeight="Black" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Real-time updates" FontSize="10" FontWeight="Medium" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        
                        <StackPanel x:Name="DiagnosticLogsPanel">
                            <!-- Logs injected here dynamically by code-->
                        </StackPanel>
                    </StackPanel>

                    <!-- Action Area -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,48,0,0">
                        <!-- End/Cancel Button -->
                        <Button x:Name="EndTestBtn" Foreground="{DynamicResource FailRedBrush}" Background="Transparent" BorderThickness="0"
                                Style="{StaticResource MaterialDesignFlatButton}" Height="48" Padding="24,0" Click="EndTestBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Close" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock x:Name="EndTestBtnText" Text="CANCEL DIAGNOSTICS" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══ Stage 5: Results Detail ═══ -->
        <Grid x:Name="ResultsContainer" Visibility="Collapsed" Background="{DynamicResource AppBackgroundBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel HorizontalAlignment="Center" MaxWidth="720" Margin="24,32,24,48" Width="720">

                    <!-- Summary Header -->
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Padding="28" Margin="0,0,0,24"
                            BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Pengujian Selesai" FontSize="28" FontWeight="Black" Foreground="{DynamicResource TextDarkBrush}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="ResultSummaryText" Text="" FontSize="14" Foreground="{DynamicResource TextLightBrush}"/>
                            </StackPanel>

                            <!-- Overall Status Badge -->
                            <Border x:Name="ResultStatusBadge" Grid.Column="1" CornerRadius="16" Padding="20,10" VerticalAlignment="Center"
                                    Background="{DynamicResource PrimaryLightBrush}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="ResultStatusText" Text="PASS" FontSize="22" FontWeight="Black" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource PassGreenBrush}"/>
                                    <TextBlock x:Name="ResultScoreText" Text="7/7 test passed" FontSize="11" Foreground="{DynamicResource TextLightBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Results Cards -->
                    <StackPanel x:Name="ResultCardsPanel">
                        <!-- Filled dynamically -->
                    </StackPanel>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                        <Button Height="48" Padding="24,0" Margin="0,0,12,0"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="12"
                                Background="{DynamicResource PrimaryBrush}" BorderBrush="{DynamicResource PrimaryBrush}" Foreground="White"
                                Click="NewTestFromResults_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Pengujian Baru" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="RetryFailedBtn" Height="48" Padding="24,0" Margin="0,0,12,0"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="12"
                                Background="{DynamicResource WarnYellowBrush}" BorderBrush="{DynamicResource WarnYellowBrush}" Foreground="Black"
                                Click="RetryFailedBtn_Click" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Coba Ulang Gagal" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="SaveReportBtn"
                                Height="48" Padding="24,0"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="12"
                                BorderBrush="{DynamicResource BorderLightBrush}" Foreground="{DynamicResource TextDarkBrush}"
                                Click="SaveReportBtn_Click" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FilePdfBox" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Simpan PDF" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
