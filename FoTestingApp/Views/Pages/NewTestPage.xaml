<Page x:Class="FoTestingApp.Views.Pages.NewTestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Pengujian Baru">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,32">
            <TextBlock Text="Pengujian Baru" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource JinomDarkBlueBrush}"/>
            <TextBlock Text="Isi data pelanggan di bawah ini, lalu mulai eksekusi pengujian jaringan." FontSize="15" Foreground="#64748B"/>
        </StackPanel>

        <!-- Customer Form -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="{StaticResource CardCornerRadius}" Padding="28"
                Effect="{DynamicResource MaterialDesignShadowDepth2}" Margin="0,0,0,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.ColumnSpan="3" Text="1. Data Pelanggan" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource JinomDarkBlueBrush}" Margin="0,0,0,16" Grid.Row="0"/>

                <!-- Mode Selection -->
                <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,20" HorizontalAlignment="Right">
                    <TextBlock Text="Mode Uji:" VerticalAlignment="Center" Margin="0,0,16,0" FontWeight="SemiBold" Foreground="#64748B"/>
                    <RadioButton x:Name="PopModeBtn" Content="POP" GroupName="TestMode" Checked="TestMode_Changed"/>
                    <RadioButton x:Name="CustomerModeBtn" Content="Pelanggan" GroupName="TestMode" IsChecked="True" Checked="TestMode_Changed" Margin="24,0,0,0"/>
                </StackPanel>

                <!-- Customer Search -->
                <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,0,0,8">
                    <TextBox x:Name="SearchBox"
                             materialDesign:HintAssist.Hint="🔍 Cari pelanggan (nama / no. pelanggan)..."
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Width="320" Height="40" VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged"/>
                    <ListBox x:Name="SearchDropdown"
                             Visibility="Collapsed"
                             MaxHeight="200" Width="320"
                             SelectionChanged="SearchDropdown_SelectionChanged"
                             Panel.ZIndex="100"
                             Background="White"
                             BorderThickness="1" BorderBrush="#E2E8F0"
                             HorizontalAlignment="Left">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="4">
                                    <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="14" Foreground="#1E293B"/>
                                    <TextBlock Text="{Binding CustomerNumber}" FontSize="12" Foreground="#64748B"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>


                <TextBox Grid.Row="1" Grid.Column="0"
                         x:Name="SiteIdBox"
                         materialDesign:HintAssist.Hint="Site ID *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16" Height="48" VerticalContentAlignment="Center"/>

                <TextBox Grid.Row="1" Grid.Column="2"
                         x:Name="FullNameBox"
                         materialDesign:HintAssist.Hint="Nama Lengkap *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16" Height="48" VerticalContentAlignment="Center"/>

                <TextBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                         x:Name="AddressBox"
                         materialDesign:HintAssist.Hint="Alamat Instalasi *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16" Height="48" VerticalContentAlignment="Center"/>

                <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                         x:Name="PackageMbpsBox"
                         materialDesign:HintAssist.Hint="Paket Layanan (Mbps) *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16" Height="48" VerticalContentAlignment="Center"/>

                <TextBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                         x:Name="NotesBox"
                         materialDesign:HintAssist.Hint="Catatan Teknis (opsional)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Height="80" AcceptsReturn="True" TextWrapping="Wrap" Padding="12,12"/>
            </Grid>
        </Border>

        <!-- Test Execution Area -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="{StaticResource CardCornerRadius}" Padding="28"
                Effect="{DynamicResource MaterialDesignShadowDepth2}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
                    <TextBlock Text="2. Eksekusi Pengujian" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource JinomDarkBlueBrush}" VerticalAlignment="Center"/>
                    <Button x:Name="StartTestBtn"
                            Content="▶  MULAI TEST"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="{StaticResource ButtonCornerRadius}"
                            Background="{DynamicResource JinomBlueBrush}" BorderBrush="{DynamicResource JinomBlueBrush}" Foreground="White"
                            Margin="24,0,0,0" Padding="24,0" Height="44" FontSize="14" FontWeight="Bold"
                            Click="StartTestBtn_Click"/>
                    <Button x:Name="SaveReportBtn"
                            Content="💾  Simpan &amp; Cetak Laporan"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="{StaticResource ButtonCornerRadius}"
                            Background="{DynamicResource PassGreenBrush}" BorderBrush="{DynamicResource PassGreenBrush}" Foreground="White"
                            Margin="12,0,0,0" Padding="20,0" Height="44" FontSize="14" FontWeight="Bold"
                            IsEnabled="False"
                            Click="SaveReportBtn_Click"/>
                </StackPanel>

                <!-- Progress Bar -->
                <ProgressBar x:Name="TestProgressBar" Grid.Row="1"
                             Style="{StaticResource MaterialDesignLinearProgressBar}"
                             IsIndeterminate="False" Value="0" Maximum="100"
                             Height="6" Margin="0,0,0,8" Foreground="{DynamicResource JinomBlueBrush}"/>

                <TextBlock x:Name="StatusLabel" Grid.Row="1"
                           Text="Siap memulai pengujian." Foreground="#64748B"
                           FontSize="13" Margin="0,16,0,12"/>

                <!-- Results Panel (akan diisi saat test berjalan) -->
                <ScrollViewer Grid.Row="2" x:Name="ResultsScrollViewer">
                    <StackPanel x:Name="ResultsPanel"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
