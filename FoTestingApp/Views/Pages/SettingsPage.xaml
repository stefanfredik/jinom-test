<Page x:Class="FoTestingApp.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Pengaturan">
    <ScrollViewer>
        <StackPanel Margin="32">
            <TextBlock Text="Pengaturan Sistem" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}" Margin="0,0,0,8"/>
            <TextBlock Text="Konfigurasi parameter pengujian (khusus Admin)" Foreground="{DynamicResource TextLightBrush}" Margin="0,0,0,24"/>

            <!-- Network Test Settings -->
            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="24"
                    Effect="{DynamicResource MaterialDesignShadowDepth1}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Parameter Pengujian Jaringan" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextDarkBrush}" Margin="0,0,0,16"/>

                    <UniformGrid Columns="2" Margin="0,0,0,8">
                        <StackPanel Margin="0,0,8,0">
                            <TextBox x:Name="DnsTargetBox" materialDesign:HintAssist.Hint="IP DNS Target Ping" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12"/>
                            <TextBox x:Name="PingGwCountBox" materialDesign:HintAssist.Hint="Jumlah Ping Gateway" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12"/>
                            <TextBox x:Name="PingDnsCountBox" materialDesign:HintAssist.Hint="Jumlah Ping DNS" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12"/>
                            <TextBox x:Name="PingLocalTargetBox" materialDesign:HintAssist.Hint="Domain Ping Lokal (koma)" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        </StackPanel>
                        <StackPanel Margin="8,0,0,0">
                            <TextBox x:Name="NslookupNasionalBox" materialDesign:HintAssist.Hint="Domain NSLookup Nasional (koma)" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12"/>
                            <TextBox x:Name="NslookupInternasionalBox" materialDesign:HintAssist.Hint="Domain NSLookup Internasional (koma)" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12"/>
                            <TextBox x:Name="SpeedtestThresholdBox" materialDesign:HintAssist.Hint="Threshold Speedtest (%)" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12"/>
                            <TextBox x:Name="SessionTimeoutBox" materialDesign:HintAssist.Hint="Timeout Sesi (menit)" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Button Content="💾  Simpan Pengaturan"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderBrush="{DynamicResource PrimaryBrush}"
                    HorizontalAlignment="Left" Padding="24,8"
                    Click="SaveSettingsBtn_Click"/>
        </StackPanel>
    </ScrollViewer>
</Page>
