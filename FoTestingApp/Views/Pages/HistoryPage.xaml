<Page x:Class="FoTestingApp.Views.Pages.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Riwayat Pengujian">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Riwayat Pengujian" FontSize="24" FontWeight="Bold"
                   Foreground="#1E5AA0" Margin="0,0,0,20"/>

        <!-- Filters -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16"
                Effect="{DynamicResource MaterialDesignShadowDepth1}" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <DatePicker x:Name="FromDatePicker" materialDesign:HintAssist.Hint="Dari Tanggal"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" Width="160"/>
                <DatePicker x:Name="ToDatePicker" materialDesign:HintAssist.Hint="Sampai Tanggal"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" Width="160"/>
                <ComboBox x:Name="StatusFilter" materialDesign:HintAssist.Hint="Status"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" Width="120">
                    <ComboBoxItem Content="Semua"/>
                    <ComboBoxItem Content="PASS"/>
                    <ComboBoxItem Content="FAIL"/>
                    <ComboBoxItem Content="PARTIAL"/>
                </ComboBox>
                <Button Content="🔍 Filter" Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#1E5AA0" Foreground="White" Click="FilterBtn_Click"/>
            </StackPanel>
        </Border>

        <!-- Sessions DataGrid -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="16"
                Effect="{DynamicResource MaterialDesignShadowDepth1}">
            <DataGrid x:Name="SessionsGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Style="{StaticResource MaterialDesignDataGrid}"
                      BorderThickness="0" GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID Sertifikasi" Binding="{Binding CertificationId}" Width="180"/>
                    <DataGridTextColumn Header="Pelanggan" Binding="{Binding Customer.FullName}" Width="*"/>
                    <DataGridTextColumn Header="No. Pelanggan" Binding="{Binding Customer.CustomerNumber}" Width="120"/>
                    <DataGridTextColumn Header="Paket" Binding="{Binding Customer.PackageMbps, StringFormat='{}{0} Mbps'}" Width="90"/>
                    <DataGridTextColumn Header="Teknisi" Binding="{Binding Technician.Name}" Width="130"/>
                    <DataGridTextColumn Header="Tanggal" Binding="{Binding TestDate, StringFormat='dd/MM/yyyy HH:mm'}" Width="140"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding OverallStatus}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
