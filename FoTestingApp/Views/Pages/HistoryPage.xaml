<Page x:Class="FoTestingApp.Views.Pages.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Riwayat Pengujian">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Riwayat Pengujian" FontSize="28" FontWeight="Bold"
                   Foreground="{DynamicResource TextDarkBrush}" Margin="0,0,0,24"/>

        <!-- Filters -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="{StaticResource CardCornerRadius}" Padding="20"
                Effect="{DynamicResource MaterialDesignShadowDepth2}" Margin="0,0,0,24">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <DatePicker x:Name="FromDatePicker" materialDesign:HintAssist.Hint="Dari Tanggal"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" Width="160" Margin="0,0,16,8"/>
                <DatePicker x:Name="ToDatePicker" materialDesign:HintAssist.Hint="Sampai Tanggal"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" Width="160" Margin="0,0,16,8"/>
                <ComboBox x:Name="StatusFilter" materialDesign:HintAssist.Hint="Status Pengujian"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" Width="160" Margin="0,0,16,8">
                    <ComboBoxItem Content="Semua Status"/>
                    <ComboBoxItem Content="PASS"/>
                    <ComboBoxItem Content="FAIL"/>
                    <ComboBoxItem Content="PARTIAL"/>
                </ComboBox>
                <Button Content="Terapkan Filter" Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{DynamicResource PrimaryBrush}" BorderBrush="{DynamicResource PrimaryBrush}"
                        Foreground="White" Click="FilterBtn_Click" Margin="0,4,0,8" Height="48"
                        materialDesign:ButtonAssist.CornerRadius="{StaticResource ButtonCornerRadius}">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FilterVariant" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Terapkan" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </WrapPanel>
        </Border>

        <!-- Sessions DataGrid -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="{StaticResource CardCornerRadius}" Padding="24"
                Effect="{DynamicResource MaterialDesignShadowDepth2}">
            <DataGrid x:Name="SessionsGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Style="{StaticResource MaterialDesignDataGrid}"
                      BorderThickness="0" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E2E8F0" RowHeight="56" FontSize="14">
                      
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="16,12"/>
                    </Style>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                        <Setter Property="Padding" Value="16,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type DataGridCell}">
                                    <Border Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                        <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID Sertifikasi" Binding="{Binding CertificationId}" Width="200"/>
                    <DataGridTextColumn Header="Pelanggan" Binding="{Binding Customer.FullName}" Width="*"/>
                    <DataGridTextColumn Header="Tipe Site" Binding="{Binding Customer.SiteType}" Width="110"/>
                    <DataGridTextColumn Header="Paket" Binding="{Binding Customer.PackageMbps, StringFormat='{}{0} Mbps'}" Width="100"/>
                    <DataGridTextColumn Header="Teknisi" Binding="{Binding Technician.Name}" Width="140"/>
                    <DataGridTextColumn Header="Waktu Dibuat" Binding="{Binding TestDate, StringFormat='dd MMM yyyy, HH:mm'}" Width="200"/>
                    
                    <DataGridTemplateColumn Header="Status" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="12,4" HorizontalAlignment="Left"
                                        Background="{Binding OverallStatus, Converter={StaticResource StatusToBackgroundConverter}}">
                                    <TextBlock Text="{Binding OverallStatus}" FontSize="12" FontWeight="Bold"
                                               Foreground="{Binding OverallStatus, Converter={StaticResource StatusToForegroundConverter}}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
