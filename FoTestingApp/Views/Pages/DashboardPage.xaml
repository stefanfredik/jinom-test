<Page x:Class="FoTestingApp.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Dashboard">
    <ScrollViewer>
        <StackPanel Margin="32">
            <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold" Foreground="#1E5AA0" Margin="0,0,0,8"/>
            <TextBlock Text="Ringkasan aktivitas pengujian jaringan fiber optik" Foreground="#666" Margin="0,0,0,28"/>

            <!-- Stats Cards -->
            <UniformGrid Columns="3" Margin="0,0,0,28">
                <Border Background="White" CornerRadius="8" Margin="0,0,12,0" Padding="20"
                        Effect="{DynamicResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="CheckCircle" Width="32" Height="32" Foreground="#27AE60" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TotalPassCount" Text="0" FontSize="32" FontWeight="Bold" Foreground="#27AE60"/>
                        <TextBlock Text="Sesi PASS" Foreground="#666" FontSize="13"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="8" Margin="6,0,6,0" Padding="20"
                        Effect="{DynamicResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="CloseCircle" Width="32" Height="32" Foreground="#E74C3C" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TotalFailCount" Text="0" FontSize="32" FontWeight="Bold" Foreground="#E74C3C"/>
                        <TextBlock Text="Sesi FAIL" Foreground="#666" FontSize="13"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="8" Margin="12,0,0,0" Padding="20"
                        Effect="{DynamicResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="ChartLine" Width="32" Height="32" Foreground="#1E5AA0" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TotalSessionCount" Text="0" FontSize="32" FontWeight="Bold" Foreground="#1E5AA0"/>
                        <TextBlock Text="Total Sesi" Foreground="#666" FontSize="13"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Recent Sessions Table -->
            <Border Background="White" CornerRadius="8" Padding="20"
                    Effect="{DynamicResource MaterialDesignShadowDepth1}">
                <StackPanel>
                    <TextBlock Text="Sesi Pengujian Terbaru" FontSize="15" FontWeight="SemiBold"
                               Foreground="#333" Margin="0,0,0,12"/>
                    <DataGrid x:Name="RecentSessionsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID Sertifikasi" Binding="{Binding CertificationId}" Width="180"/>
                            <DataGridTextColumn Header="Pelanggan" Binding="{Binding Customer.FullName}" Width="*"/>
                            <DataGridTextColumn Header="Paket" Binding="{Binding Customer.PackageMbps, StringFormat='{}{0} Mbps'}" Width="90"/>
                            <DataGridTextColumn Header="Tanggal" Binding="{Binding TestDate, StringFormat='dd/MM/yyyy HH:mm'}" Width="140"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding OverallStatus}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
