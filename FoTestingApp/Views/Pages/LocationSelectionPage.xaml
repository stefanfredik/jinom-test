<Page x:Class="FoTestingApp.Views.Pages.LocationSelectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      Background="{DynamicResource AppBackgroundBrush}"
      Title="LocationSelectionPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar Navigation -->
            <ColumnDefinition Width="250" />
            <!-- Main Content Area -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="70" />
            <!-- Body -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header / Top Bar (Spans across both columns) -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1" Background="{DynamicResource CardBackgroundBrush}">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="LanConnect" Foreground="{DynamicResource PrimaryBrush}" Width="32" Height="32" />
                    <TextBlock Text="NetPulse" FontSize="20" FontWeight="Bold" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextDarkBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource PrimaryLightBrush}" BorderBrush="#33ec5b13" BorderThickness="1" CornerRadius="16" Padding="12,4" Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="NETWORK ONLINE" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- Mock Avatar -->
                    <Ellipse Width="40" Height="40" Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="2" Fill="{DynamicResource BorderLightBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sidebar Navigation -->
        <Border Grid.Row="1" Grid.Column="0" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,1,0" Background="{DynamicResource CardBackgroundBrush}">
            <StackPanel Margin="16">
                <!-- User Info -->
                <StackPanel Orientation="Horizontal" Margin="12,16,12,24">
                    <Border Background="#33ec5b13" CornerRadius="8" Padding="8">
                        <materialDesign:PackIcon Kind="Person" Foreground="{DynamicResource PrimaryBrush}" Width="24" Height="24" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Admin Portal" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}" />
                        <TextBlock Text="Network Engineer" FontSize="12" Foreground="{DynamicResource TextLightBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Navigation Links -->
                <ListBox Background="Transparent" BorderThickness="0" Margin="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBoxItem Padding="12,10" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Foreground="{DynamicResource TextDarkBrush}" Width="20" Height="20" />
                            <TextBlock Text="Dashboard" FontSize="14" FontWeight="SemiBold" Margin="12,0,0,0" Foreground="{DynamicResource TextDarkBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Padding="12,10" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="GoogleAnalytics" Foreground="{DynamicResource TextDarkBrush}" Width="20" Height="20" />
                            <TextBlock Text="Tests" FontSize="14" FontWeight="SemiBold" Margin="12,0,0,0" Foreground="{DynamicResource TextDarkBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Background="{DynamicResource PrimaryBrush}" Padding="12,10" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="MapMarker" Foreground="White" Width="20" Height="20" />
                            <TextBlock Text="Locations" FontSize="14" FontWeight="Bold" Margin="12,0,0,0" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Padding="12,10" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Settings" Foreground="{DynamicResource TextDarkBrush}" Width="20" Height="20" />
                            <TextBlock Text="Settings" FontSize="14" FontWeight="SemiBold" Margin="12,0,0,0" Foreground="{DynamicResource TextDarkBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="1000" Margin="48,48,48,48" HorizontalAlignment="Stretch">
                
                <!-- Page Title -->
                <TextBlock Text="Choose Testing Location" FontSize="40" FontWeight="Black" Foreground="{DynamicResource TextDarkBrush}" Margin="0,0,0,12" />
                <TextBlock Text="Select the environment you want to analyze and monitor in real-time." FontSize="18" Foreground="{DynamicResource TextLightBrush}" Margin="0,0,0,40" />

                <!-- Location Cards Grid -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="32" /> <!-- Gutter -->
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- POP Testing Card -->
                    <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" 
                            BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1" ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Color="Black" Opacity="0.05" />
                        </Border.Effect>
                        <StackPanel>
                            <!-- Image Holder -->
                            <Grid Height="200" Background="#E2E8F0">
                                <!-- Simulated Image -->
                                <materialDesign:PackIcon Kind="Hub" Foreground="White" Width="32" Height="32" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="16" />
                            </Grid>
                            
                            <!-- Card Content -->
                            <StackPanel Margin="24">
                                <TextBlock Text="POP Testing" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}" Margin="0,0,0,8" />
                                <TextBlock Text="Analyze backbone performance, latency, and throughput at regional Point of Presence locations." FontSize="14" Foreground="{DynamicResource TextLightBrush}" TextWrapping="Wrap" Margin="0,0,0,24" />
                                
                                <Border BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                                    <Grid>
                                        <TextBlock Text="INFRASTRUCTURE FOCUS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextLightBrush}" VerticalAlignment="Center" />
                                        <Button x:Name="BtnSelectPop" Content="Select POP" Click="BtnSelectPop_Click" HorizontalAlignment="Right" Height="40" 
                                                Style="{StaticResource MaterialDesignRaisedButton}" 
                                                materialDesign:ButtonAssist.CornerRadius="8" 
                                                Background="{DynamicResource PrimaryBrush}" BorderBrush="{DynamicResource PrimaryBrush}" 
                                                Foreground="White" FontWeight="Bold" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Customer Testing Card -->
                    <Border Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" 
                            BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1" ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Color="Black" Opacity="0.05" />
                        </Border.Effect>
                        <StackPanel>
                            <!-- Image Holder -->
                            <Grid Height="200" Background="#E2E8F0">
                                <!-- Simulated Image -->
                                <materialDesign:PackIcon Kind="RouterWireless" Foreground="White" Width="32" Height="32" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="16" />
                            </Grid>
                            
                            <!-- Card Content -->
                            <StackPanel Margin="24">
                                <TextBlock Text="Customer Testing" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}" Margin="0,0,0,8" />
                                <TextBlock Text="Measure true end-user experience, local Wi-Fi stability, and last-mile connectivity metrics." FontSize="14" Foreground="{DynamicResource TextLightBrush}" TextWrapping="Wrap" Margin="0,0,0,24" />
                                
                                <Border BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                                    <Grid>
                                        <TextBlock Text="EDGE PERFORMANCE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextLightBrush}" VerticalAlignment="Center" />
                                        <Button x:Name="BtnSelectCustomer" Content="Select Customer" Click="BtnSelectCustomer_Click" HorizontalAlignment="Right" Height="40"
                                                Style="{StaticResource MaterialDesignRaisedButton}" 
                                                materialDesign:ButtonAssist.CornerRadius="8" 
                                                Background="{DynamicResource PrimaryBrush}" BorderBrush="{DynamicResource PrimaryBrush}" 
                                                Foreground="White" FontWeight="Bold" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Footer Summary -->
                <Border Background="{DynamicResource PrimaryLightBrush}" BorderBrush="#40ec5b13" BorderThickness="1" CornerRadius="16" Padding="24" Margin="0,48,0,48">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Background="#33ec5b13" CornerRadius="24" Width="48" Height="48" Margin="0,0,16,0">
                            <materialDesign:PackIcon Kind="InformationOutline" Foreground="{DynamicResource PrimaryBrush}" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Need help choosing?" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}" />
                            <TextBlock Text="Read our documentation on testing methodologies and best practices." FontSize="14" Foreground="{DynamicResource TextLightBrush}" />
                        </StackPanel>
                        
                        <TextBlock Grid.Column="2" Text="View User Guide" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" TextDecorations="Underline" VerticalAlignment="Center" Cursor="Hand" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
