<Application x:Class="FoTestingApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:FoTestingApp.Helpers"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light"
                                             PrimaryColor="Green"
                                             SecondaryColor="Teal" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Primary Brand Color - Jinom Green -->
            <Color x:Key="NetPulsePrimary">#22c55e</Color>
            <Color x:Key="NetPulseDark">#071a0e</Color>
            
            <SolidColorBrush x:Key="PrimaryBrush" Color="#22c55e" />
            <SolidColorBrush x:Key="PrimaryLightBrush" Color="#dcfce7" />
            <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#16a34a" />
            <SolidColorBrush x:Key="DarkOverlayBrush" Color="#0a1f10" />
            <SolidColorBrush x:Key="PassGreenBrush" Color="#10B981" />
            <SolidColorBrush x:Key="FailRedBrush" Color="#EF4444" />
            <SolidColorBrush x:Key="WarnYellowBrush" Color="#F59E0B" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#f8f6f6" />
            <SolidColorBrush x:Key="TextDarkBrush" Color="#0f172a" /> <!-- slate-900 -->
            <SolidColorBrush x:Key="TextLightBrush" Color="#64748b" /> <!-- slate-500 -->
            <SolidColorBrush x:Key="BorderLightBrush" Color="#e2e8f0" /> <!-- slate-200 -->

            <!-- Global Shadow Depth and Corners -->
            <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>
            <CornerRadius x:Key="InputCornerRadius">12</CornerRadius>
            <CornerRadius x:Key="ButtonCornerRadius">12</CornerRadius>
            
            <!-- Value Converters -->
            <helpers:StatusToBackgroundConverter x:Key="StatusToBackgroundConverter"/>
            <helpers:StatusToForegroundConverter x:Key="StatusToForegroundConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
